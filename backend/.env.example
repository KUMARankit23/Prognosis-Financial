PORT=5000
NODE_ENV=development

# MongoDB - Local (MongoDB Compass / Community Server)
# For local development:
MONGODB_URI=mongodb://localhost:27017/prognosis_financial
# For MongoDB Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/prognosis_financial

# Google Gemini AI (free — 1000 req/day)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin Credentials
ADMIN_EMAIL=admin@prognosisfinancial.com
ADMIN_PASSWORD=Admin@1234

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
